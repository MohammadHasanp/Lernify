@page
@model Lernify.Web.Pages.Auth.LoginModel
@{
    ViewData["title"] = "ورود به حساب";
    Layout = "Shared/_Auth";
}
<form method="post" class="login mt-4 pt-0">
    <div class="emailOrUserName">
        <p> شماره تلفن</p>
        <input type="number" asp-for="@Model.Mobile" class="form-control" required />
    </div>
    <div class="password mt-5">
        <p>کلمه عبور </p>
        <input type="password" asp-for="@Model.Password" class="form-control" required />
    </div>
    <div class="checkbox mt-4">
        <input type="checkbox" asp-for="@Model.IsRememberMe" value="true" id="check1" />
        <span checkfor="check1">مرا بخاطر بسپار</span>
    </div>
    <button class="btn btn-success btn-login mt-4 d-flex justify-content-center align-items-center">
        <span> ورود</span>
        <i class="fa fa-chevron-left"></i>
    </button>
</form>
<div class="login-footer">
    <a href="#">
        <i class="zmdi zmdi-lock"></i>
        کلمه عبور خود را فراموش کرده ام !
    </a>
    <a asp-page="Register">
        <i class="zmdi zmdi-account-add"></i>
        عضویت در سایت
    </a>
</div>
