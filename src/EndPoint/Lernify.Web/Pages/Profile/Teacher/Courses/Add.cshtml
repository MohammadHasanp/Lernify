@page
@using CoreModule.Domain.Courses.Enums
@using CoreModule.Facade.CourseCategories
@inject ICourseCategoryFacade CategoryFacade
@model Lernify.Web.Pages.Profile.Teacher.Courses.AddModel
@{
    ViewData["Title"] = "افزودن دوره";
    Layout = "Shared/_ProfileLayout";
    var categories = await CategoryFacade.GetMainCategory();
}
<div class="row">
    <div class="col-12 info shadow pl-0 pr-0">
        <p class="title">
            <i class="fa fa-paper-plane"></i>
            @ViewData["Title"]
        </p>
        <div class="info-body p-2">
            <form method="post" class="row" enctype="multipart/form-data">
                <div class="col-6">
                    <label asp-for="@Model.Title"></label>
                    <input asp-for="Title" type="text" class="form-control">
                    <span class="text-danger" asp-validation-for="Title"></span>
                </div>

                <div class="col-6">
                    <label asp-for="@Model.Slug"></label>
                    <input asp-for="@Model.Slug" type="text" class="form-control" />
                    <span class="text-danger" asp-validation-for="@Model.Slug"></span>
                </div>

                <div class="col-6">
                    <label asp-for="@Model.CategoryId"></label>
                    <select asp-for="@Model.CategoryId" class="form-control">
                        <option>انتخاب کنید</option>
                        @foreach (var item in categories)
                        {
                            <option value="@item.Id">@item.Title</option>
                        }
                    </select>
                </div>

                <div class="col-6">
                    <label asp-for="@Model.SubCategoryId"></label>
                    <select asp-for="@Model.SubCategoryId" class="form-control">
                    </select>
                </div>

                <div class="col-6">
                    <label asp-for="@Model.CourseLevel"></label>
                    <select asp-for="@Model.CourseLevel" class="form-control">
                        <option value="@CourseLevel.Beginner">مقدماتی</option>
                        <option value="@CourseLevel.Intermediate">از مقدماتی تا پیشرفته</option>
                        <option value="@CourseLevel.Expert">پیشرفته</option>

                    </select>
                </div>

                <div class="col-6">
                    <label asp-for="@Model.Price"></label>
                    <input asp-for="@Model.Price" type="number" class="form-control" />
                    <span class="text-danger" asp-validation-for="@Model.Price"></span>
                </div>

                <div class="col-12">
                    <label asp-for="@Model.Description"></label>
                    <textarea id="ckeditor" asp-for="@Model.Description" class="form-control"></textarea>
                    <span class="text-danger" asp-validation-for="@Model.Description"></span>
                </div>

                <div class="col-6">
                    <label asp-for="@Model.ImageFile"></label>
                    <input asp-for="@Model.ImageFile" type="File" class="form-control" />
                    <span class="text-danger" asp-validation-for="@Model.ImageFile"></span>
                </div>

                <div class="col-6">
                    <label asp-for="@Model.VideoFile"></label>
                    <input asp-for="@Model.VideoFile" type="File" class="form-control" />
                    <span class="text-danger" asp-validation-for="@Model.VideoFile"></span>
                </div>

                <div class="col-12 ">
                    <button type="submit" class="btn  btn-save  mt-2">ثبت اطلاعات</button>
                </div>
            </form>
        </div>
    </div>
</div>


@section scripts
{
    <script>
        $("#CategoryId").change(function () {
            var id = $(this).val();
            $.ajax({
                url: "/ajax/getCategoryChildsren?id=" + id,
                method: "get"
            }).done(function (data) {
                $("#SubCategoryId").html(data);
            });
        });
    </script>
}